PORT=4000
APP_BASE_URL=http://localhost:4000
JWT_SECRET=replace_with_strong_secret
OTP_TTL_SECONDS=300
SESSION_TTL_MINUTES=20
PARENT_OTP_TTL_MINUTES=5

# PostgreSQL SQL database (choose either DATABASE_URL or PG_* fields)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parent_chatbot
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=parent_chatbot
PG_SSL=false
PG_POOL_MAX=20

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=replace_with_verify_token
WHATSAPP_ACCESS_TOKEN=replace_with_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_phone_number_id

# Firebase Admin (required for /api/parent/firebase/verify-otp)
# Option A: set GOOGLE_APPLICATION_CREDENTIALS to service-account JSON path
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: paste full service-account JSON in one line
FIREBASE_SERVICE_ACCOUNT_KEY_JSON=

# SMS OTP delivery — Fast2SMS (India, free tier: https://www.fast2sms.com)
# Sign up → Dashboard → Dev API → copy API Key
FAST2SMS_API_KEY=

# SMS OTP delivery — Twilio (global, free trial: https://www.twilio.com)
# Sign up → Console → Project Info (Account SID + Auth Token)
# Twilio number: buy a number in Console (free trial gives one)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Admin setup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisAdminPassword!
